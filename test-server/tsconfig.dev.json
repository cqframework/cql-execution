{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "..",
    "paths": {
      "@src/*": ["src/*"],
      "cql-execution": ["../src/cql.ts"],
      "cql-execution/lib/*": ["../src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.mts", "src/**/*.d.ts", "../src/**/*.ts", "../src/**/*.d.ts"]
}
